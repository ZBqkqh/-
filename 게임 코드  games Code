def boss_1(app):
    app.clear(); app.game_active = True; app.current_game_id = "boss"
    app.time_left = 20.0; app.boss_hits = 0; b_size = 200
    app.canvas.create_text(app.WIDTH/2, 80, text="CH 1 BOSS! 10번 때려라!", fill="red", font=("Arial", 40, "bold"))
    htxt = app.canvas.create_text(app.WIDTH/2, 130, text="Hits: 0 / 10", fill="white", font=("Arial", 30))
    app.bx, app.by = app.WIDTH/2, app.HEIGHT/2
    bid = app.canvas.create_oval(app.bx-b_size/2, app.by-b_size/2, app.bx+b_size/2, app.by+b_size/2, fill="#880000", outline="red", width=5)
    bullets = []
    
    def on_click(e):
        if not app.game_active: return
        c = app.canvas.coords(bid)
        if c and c[0] <= e.x <= c[2] and c[1] <= e.y <= c[3]:
            app.boss_hits += 1; app.canvas.itemconfig(htxt, text=f"Hits: {app.boss_hits} / 10")
            if app.boss_hits >= 10: app.end_minigame(True)
            else:
                app.bx, app.by = random.randint(200, app.WIDTH-200), random.randint(250, app.HEIGHT-250)
                app.canvas.coords(bid, app.bx-b_size/2, app.by-b_size/2, app.bx+b_size/2, app.by+b_size/2)
    app.canvas.bind("<Button-1>", on_click)
    
    def update():
        if not app.game_active or app.current_game_id != "boss": return
        if random.random() < 0.05 * app.speed:
            ang = random.uniform(0, math.pi * 2); spd = random.randint(10, 15) * app.speed
            b = app.canvas.create_oval(app.bx-10, app.by-10, app.bx+10, app.by+10, fill="orange", outline="")
            bullets.append({"id": b, "dx": math.cos(ang)*spd, "dy": math.sin(ang)*spd})
        for b in bullets[:]:
            app.canvas.move(b["id"], b["dx"], b["dy"])
            c = app.canvas.coords(b["id"])
            if c and (c[2] < 0 or c[0] > app.WIDTH or c[3] < 0 or c[1] > app.HEIGHT):
                app.canvas.delete(b["id"]); bullets.remove(b)
        app.root.after(30, update)
    app.root.bind("<Motion>", lambda e: app.end_minigame(False) if any(c := app.canvas.coords(b["id"]) for b in bullets if c and c[0]<=e.x<=c[2] and c[1]<=e.y<=c[3]) else None)
    update(); app.tick_timer()

